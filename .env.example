# Browser-visible Supabase configuration. RLS protects all data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only, pooled connection using a restricted application database role.
DATABASE_URL=

# GitHub App server credentials. Never expose these to the browser.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Shared HMAC secret for the isolated Pilot GitHub Actions callback.
PILOT_CALLBACK_SECRET=

# Canonical Vercel deployment URL, for example https://app.deploygrade.com
APP_BASE_URL=
