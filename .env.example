# DeployGrade runtime configuration template. Copy to .env locally; never commit .env.
# Place real values in your deployment platform's encrypted secret store.

# Required for the authenticated control-plane API outside tests.
DEPLOYGRADE_ENVIRONMENT=development
# Development uses SQLite only. Production requires the managed Postgres adapter
# and OIDC identity provider variables below; it will fail closed if this local
# backend is selected.
DEPLOYGRADE_CONTROL_PLANE_DB=/var/lib/deploygrade/control-plane.sqlite3
DEPLOYGRADE_CONTROL_PLANE_BACKEND=sqlite
DEPLOYGRADE_AUTH_MODE=hmac-development-only
DEPLOYGRADE_AUTH_SECRET=replace-with-a-long-random-secret
DEPLOYGRADE_OIDC_ISSUER=
DEPLOYGRADE_OIDC_AUDIENCE=
# HTTPS JWKS endpoint from the configured issuer. Production verifies each JWT
# signature with PyJWT; it never trusts decoded claims.
DEPLOYGRADE_OIDC_JWKS_URI=
DEPLOYGRADE_OIDC_ORGANIZATION_CLAIM=organization_id
DEPLOYGRADE_OIDC_ROLES_CLAIM=roles

# New production Pilot jobs receive a short-lived callback route and credential
# transactionally from the managed control plane. Do not provision a general
# callback secret in environment variables. This static map is temporary
# migration compatibility only; leave it empty for new production deployments.
DEPLOYGRADE_PILOT_CALLBACK_ROUTES=
# Development/test-only legacy ingress secret. Production rejects this mode.
PILOT_CALLBACK_SECRET=

# Optional. Set only after a real HTTPS preview/production deployment exists.
# CI conditionally runs `make verify-deployed` when the repository variable is set.
DEPLOYGRADE_DEPLOYED_URL=

# Required operational configuration for the separately deployed worker/sandbox.
# These values are deployment contracts; this repository does not launch the worker.
DEPLOYGRADE_WORKER_ENDPOINT=https://worker.example.invalid
DEPLOYGRADE_WORKER_ID=deploygrade-worker-prod
DEPLOYGRADE_WORKER_CREDENTIAL_REF=secret-manager://deploygrade/worker/credential

# Production connector credentials must be short-lived and repository-scoped.
# Store only opaque secret-manager references here, never raw SCM tokens.
DEPLOYGRADE_CONNECTOR_CREDENTIAL_REF=secret-manager://deploygrade/scm/installation

# Required only when the Supabase migration is deployed and selected as the
# production control-plane datastore. Do not place service-role values in Vercel
# browser-visible environment variables.
SUPABASE_URL=https://project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-secret

# Vercel browser-visible Supabase configuration. RLS remains the server-side
# authority; the service-role key above must never be prefixed NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=https://project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-browser-anon-key

# Server-only pooled database connection and canonical operator origin. These
# are required when the production datastore/host integration is enabled.
DATABASE_URL=postgresql://deploygrade:replace-with-password@db.example.invalid:5432/deploygrade?sslmode=verify-full
APP_BASE_URL=https://app.example.invalid

# GitHub App connector settings. The private key and webhook secret are
# server-only; use short-lived installation tokens for repository operations.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
