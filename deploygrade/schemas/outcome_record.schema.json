{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$id": "outcome_record.schema.json",
  "schema_version": "1.0",
  "required": [
    "$schema",
    "schema_version",
    "deployment_id",
    "predicted",
    "observed",
    "prediction_evidence_quality",
    "vertical",
    "source_tag",
    "anonymized_id"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "deployment_id": {
      "type": "string",
      "minLength": 1
    },
    "predicted": {
      "type": "object",
      "required": [
        "outcome",
        "score"
      ],
      "properties": {
        "outcome": {
          "type": "string",
          "minLength": 1
        },
        "score": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "observed": {
      "type": "object",
      "required": [
        "outcome",
        "evidence_uris"
      ],
      "properties": {
        "outcome": {
          "type": "string",
          "minLength": 1
        },
        "evidence_uris": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "prediction_evidence_quality": {
      "type": "object",
      "required": [
        "value",
        "method",
        "missing_evidence_uris",
        "stale_evidence_uris"
      ],
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "missing_evidence_uris": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "stale_evidence_uris": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "vertical": {
      "type": "string",
      "enum": [
        "healthcare",
        "finance",
        "retail",
        "saas",
        "public_sector"
      ]
    },
    "source_tag": {
      "type": "string",
      "enum": [
        "customer-anonymized",
        "synthetic-poison"
      ]
    },
    "anonymized_id": {
      "type": "string",
      "minLength": 16
    }
  },
  "additionalProperties": false
}
