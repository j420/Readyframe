{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deployment_inventory.schema.json",
  "x-schema-version": "2.0",
  "type": "object",
  "required": ["$schema", "schema_version", "environment", "agents", "collected_facts", "missing_evidence"],
  "properties": {
    "$schema": {"type": "string", "minLength": 1},
    "schema_version": {"type": "string", "minLength": 1},
    "environment": {"type": "string", "minLength": 1},
    "agents": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["id", "version"], "properties": {"id": {"type": "string", "minLength": 1}, "version": {"type": "string", "minLength": 1}}, "additionalProperties": false}},
    "collected_facts": {"type": "array", "items": {"type": "object", "required": ["category", "sub_score", "finding", "status", "evidence_uris", "evidence_quality"], "properties": {"category": {"type": "string", "minLength": 1}, "sub_score": {"type": "string", "minLength": 1}, "finding": {"type": "string", "minLength": 1}, "status": {"type": "string", "enum": ["present", "present_low_quality"]}, "evidence_uris": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "evidence_quality": {"type": "object", "required": ["source", "freshness", "confidence"], "properties": {"source": {"type": "string", "minLength": 1}, "freshness": {"type": "string", "minLength": 1}, "confidence": {"type": "number", "minimum": 0, "maximum": 1}}, "additionalProperties": false}}, "additionalProperties": false}},
    "missing_evidence": {"type": "array", "items": {"type": "object", "required": ["category", "sub_score", "reason", "evidence_quality"], "properties": {"category": {"type": "string", "minLength": 1}, "sub_score": {"type": "string", "minLength": 1}, "reason": {"type": "string", "minLength": 1}, "evidence_quality": {"type": "object", "required": ["source", "freshness", "confidence"], "properties": {"source": {"type": "string", "minLength": 1}, "freshness": {"type": "string", "minLength": 1}, "confidence": {"type": "number", "minimum": 0, "maximum": 1}}, "additionalProperties": false}}, "additionalProperties": false}}
  },
  "additionalProperties": false
}
