{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$id": "readiness_score.v1.schema.json",
  "schema_version": "1.0",
  "required": [
    "$schema",
    "schema_version",
    "score",
    "rubric_version"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1000
    },
    "rubric_version": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
