{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$id": "pilot_scorecard.schema.json",
  "schema_version": "1.0",
  "required": [
    "$schema",
    "schema_version",
    "deployment_id",
    "readiness_score",
    "observations",
    "metrics"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "deployment_id": {
      "type": "string",
      "minLength": 1
    },
    "readiness_score": {
      "type": "number"
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metrics": {
      "type": "object",
      "required": [
        "throughput",
        "error_rate",
        "silent_rollbacks",
        "evidence_coverage",
        "samples"
      ],
      "properties": {
        "throughput": {
          "type": "number"
        },
        "error_rate": {
          "type": "number"
        },
        "silent_rollbacks": {
          "type": "number"
        },
        "evidence_coverage": {
          "type": "number"
        },
        "samples": {
          "type": "number"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
