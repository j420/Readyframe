{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "portfolio_dashboard.schema.json",
  "type": "object",
  "required": ["$schema", "schema_version", "portfolio_id", "rows"],
  "properties": {
    "$schema": {"type": "string", "minLength": 1},
    "schema_version": {"const": "1.0"},
    "portfolio_id": {"type": "string", "minLength": 1},
    "rows": {"type": "array", "items": {"$ref": "#/$defs/row"}}
  },
  "$defs": {
    "number": {"type": "object", "required": ["value", "confidence", "evidence_uris", "rubric_version"], "properties": {"value": {"type": "number"}, "confidence": {"type": "number", "minimum": 0, "maximum": 1}, "evidence_uris": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "rubric_version": {"type": "string", "minLength": 1}}, "additionalProperties": false},
    "row": {"type": "object", "required": ["deployment_id", "vertical", "risk", "velocity", "confidence", "evidence_uris", "counterfactual", "audit_record", "action"], "properties": {"deployment_id": {"type": "string", "minLength": 1}, "vertical": {"type": "string", "minLength": 1}, "risk": {"$ref": "#/$defs/number"}, "velocity": {"$ref": "#/$defs/number"}, "confidence": {"$ref": "#/$defs/number"}, "evidence_uris": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "counterfactual": {"type": "string", "minLength": 1}, "audit_record": {"type": "string", "minLength": 1}, "action": {"type": "string", "minLength": 1}}, "additionalProperties": false}
  },
  "additionalProperties": false
}
