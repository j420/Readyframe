{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$id": "readiness_score.schema.json",
  "schema_version": "1.0",
  "required": [
    "$schema",
    "schema_version",
    "score",
    "band",
    "sub_scores",
    "confidence",
    "counterfactual",
    "audit"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "score": {
      "type": "object",
      "required": [
        "value",
        "confidence",
        "evidence_uris",
        "rubric_version"
      ],
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1000
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence_uris": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rubric_version": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "band": {
      "type": "string",
      "enum": [
        "BLOCKED",
        "CONDITIONAL",
        "READY",
        "SCALE"
      ]
    },
    "sub_scores": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "raw",
          "weight",
          "controls",
          "evidence_uris",
          "control_clauses",
          "evidence_quality"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "raw": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "controls": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "evidence_uris": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "control_clauses": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "evidence_quality": {
            "type": "object",
            "required": [
              "source",
              "freshness",
              "confidence"
            ],
            "properties": {
              "source": {
                "type": "string",
                "minLength": 1
              },
              "freshness": {
                "type": "string",
                "minLength": 1
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "confidence": {
      "type": "object",
      "required": [
        "interval_low",
        "interval_high",
        "method",
        "drivers"
      ],
      "properties": {
        "interval_low": {
          "type": "number",
          "minimum": 0,
          "maximum": 1000
        },
        "interval_high": {
          "type": "number",
          "minimum": 0,
          "maximum": 1000
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "drivers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "kind",
              "detail"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "missing_evidence",
                  "stale_data",
                  "coverage",
                  "variance"
                ]
              },
              "detail": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "counterfactual": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "action",
          "sub_score_affected",
          "projected_score_delta",
          "cost"
        ],
        "properties": {
          "action": {
            "type": "string",
            "minLength": 1
          },
          "sub_score_affected": {
            "type": "string",
            "minLength": 1
          },
          "projected_score_delta": {
            "type": "number",
            "minimum": 0
          },
          "cost": {
            "type": "number",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "audit": {
      "type": "object",
      "required": [
        "rubric_version",
        "inputs_hash",
        "engine_version",
        "generated_at",
        "signature"
      ],
      "properties": {
        "rubric_version": {
          "type": "string",
          "minLength": 1
        },
        "inputs_hash": {
          "type": "string",
          "minLength": 1
        },
        "rubric_hash": {
          "type": "string",
          "minLength": 1
        },
        "engine_version": {
          "type": "string",
          "minLength": 1
        },
        "generated_at": {
          "type": "string",
          "minLength": 1
        },
        "signature": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
