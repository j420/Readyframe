{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$id": "investigation_report.schema.json",
  "schema_version": "1.0",
  "required": [
    "$schema",
    "schema_version",
    "alert_id",
    "finding",
    "evidence_uris"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "alert_id": {
      "type": "string",
      "minLength": 1
    },
    "finding": {
      "type": "string",
      "minLength": 1
    },
    "evidence_uris": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
